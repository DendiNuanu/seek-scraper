# SEEK Employer credentials (fill in .env locally — never commit .env)
SEEK_EMAIL=your-email@company.com
# Passwords with # or ! MUST be in double quotes:
SEEK_PASSWORD="your-password-here"

# Nuanu ATS import API
NUANU_API_URL=https://hr-ats.nuanu.site/api/candidates/import-seek
NUANU_API_KEY=nuanu-seek-secret-2026

# Options (SEEK often blocks headless — use false unless login already works headless)
HEADLESS=false
# Past applicants pagination (SEEK: ?page=2, ?page=3, …)
START_PAGE=1
MAX_PAGES=40
# Stop when list rows are older than N months (6 = ~6 months of history)
MAX_AGE_MONTHS=0
# Resume after interrupt: RESUME_CHECKPOINT=true (reads scrape-checkpoint.json)
# SAVE_CHECKPOINT=false

# --- TURBO (recommended for 6 months / many pages) ---
# TURBO_MODE=true
# PARALLEL_LIST_PAGES=3
# TURBO_ENRICH=true
# ENRICH_CONCURRENCY=2
# SEEK job IDs (from candidates?jobId= URL in browser — for opening profiles)
SEEK_JOB_SITE_MANAGER=92060717
# SEEK_JOB_ACCOUNTING_OFFICER=your-job-id-here
# Map SEEK roles to ATS vacancy IDs (from dashboard job URL)
# SEEK_VACANCY_SITE_MANAGER=clxxxxxxxx
# SEEK_VACANCY_ACCOUNTING_OFFICER=clxxxxxxxx
# SCRAPE_JOBS=true
MAX_JOBS=20
DELAY_MS=3500
# Wait for SEEK list to finish rendering (top row = newest applicant)
LIST_SETTLE_MS=4500
PROFILE_SETTLE_MS=1200
# Scrape only — log names, skip API POST
SCRAPE_ONLY=false
# Open each candidate profile for email + resume (default on; false = list-only, faster)
FETCH_CONTACT_DETAILS=true
# Limit profile opens (0 = all candidates on scraped pages)
MAX_DETAIL_CANDIDATES=0
